<%= turbo_frame_tag dom_id(comment) do %>
  <div class="border-b last:border-b-0 py-4" id="<%= dom_id(comment) %>">
    <div class="flex justify-between items-start mb-2">
      <div class="font-semibold"><%= comment.user.name %></div>
      <div class="text-gray-500 text-sm"><%= time_ago_in_words(comment.created_at) %> ago</div>
    </div>
    
    <div class="comment-body mb-2">
      <%= comment.body %>
    </div>
    
    <% if comment.user == current_user %>
      <div class="flex space-x-2 text-sm">
        <%= link_to "Edit", "#", 
            class: "text-blue-500 hover:underline", 
            data: { 
              controller: "toggle", 
              action: "toggle#toggle", 
              toggle_target: "editForm" 
            } %>
        <%= button_to "Delete", [post, comment], method: :delete, 
            class: "text-red-500 hover:underline" %>
      </div>
      
      <div class="hidden mt-2" data-toggle-target="editForm">
        <%= form_with model: [post, comment], data: { controller: "character-counter" } do |form| %>
          <div class="mb-2">
            <%= form.text_area :body, 
                rows: 2, 
                required: true,
                class: "w-full border rounded-lg p-2 focus:ring-2 focus:ring-blue-300 focus:border-blue-300",
                data: { 
                  character_counter_target: "input",
                  action: "input->character-counter#count"
                } %>
            <div class="text-right text-sm text-gray-500" data-character-counter-target="counter">
              <%= comment.body.length %>/500
            </div>
          </div>
          <div class="flex space-x-2">
            <%= form.submit "Update", class: "bg-blue-500 hover:bg-blue-600 text-white py-1 px-3 rounded text-sm" %>
            <button type="button" class="text-gray-500 hover:underline text-sm"
                    data-action="toggle#toggle">Cancel</button>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
