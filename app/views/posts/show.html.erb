<div class="post__container">
  <div class="post__back-link">
    <%= link_to "← Back to Posts", posts_path, class: "button button--secondary" %>
  </div>
  
  <div class="post__content">
    <div class="post__header">
      <h1 class="post__header-title"><%= @post.title %></h1>
      
      <div class="post__header-meta">
        <div class="post__header-author">
          <span>By <%= @post.user.name %></span>
          <span>&bull;</span>
          <span><%= @post.created_at.strftime("%B %d, %Y") %></span>
        </div>
        
        <% if @post.user == current_user %>
          <div class="post__header-actions">
            <%= link_to "Edit", edit_post_path(@post), class: "button button--secondary" %>
            <%= button_to "Delete", @post, method: :delete, 
                data: { confirm: "Are you sure you want to delete this post?" }, 
                class: "button button--danger" %>
          </div>
        <% end %>
      </div>
    </div>
    
    <div class="post__body">
      <%= @post.content %>
    </div>
  </div>
  
  <div class="comments__container">
    <h2 class="comments__header">Comments</h2>
    
    <% if current_user %>
      <div class="comments__form" id="comment-form">
        <%= form_with model: [@post, @comment], 
                      data: { controller: "character-counter", 
                              action: "turbo:submit-end->character-counter#reset" } do |form| %>
          <div>
            <%= form.text_area :body, 
                placeholder: "Add a comment...", 
                rows: 3, 
                required: true,
                class: "comments__form-textarea",
                data: { 
                  character_counter_target: "input",
                  action: "input->character-counter#count"
                } %>
            <div class="comments__form-counter" data-character-counter-target="counter">0/500</div>
          </div>
          
          <%= form.submit "Post Comment", class: "comments__form-submit" %>
        <% end %>
      </div>
    <% else %>
      <div class="comments__login-prompt">
        <p class="comments__login-prompt-message">
          Please <%= link_to "sign in", root_path, class: "comments__login-prompt-link" %> to leave a comment.
        </p>
      </div>
    <% end %>
    
    <div id="comments">
      <%= turbo_stream_from @post, :comments %>
      
      <% if @comments.any? %>
        <ul class="comments__list">
          <% @comments.each do |comment| %>
            <%= render partial: "comments/comment", locals: { comment: comment, post: @post } %>
          <% end %>
        </ul>
      <% else %>
        <p class="comments__empty">No comments yet. Be the first to share your thoughts!</p>
      <% end %>
    </div>
  </div>
</div>
