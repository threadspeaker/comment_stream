<div class="container mx-auto px-4 py-6">
  <div class="mb-6">
    <%= link_to "← Back to Posts", posts_path, class: "text-blue-500 hover:underline" %>
  </div>
  
  <article class="bg-white rounded-lg shadow-md overflow-hidden mb-8">
    <div class="p-6">
      <h1 class="text-3xl font-bold mb-4"><%= @post.title %></h1>
      <div class="flex items-center text-gray-600 mb-6">
        <span>By <%= @post.user.name %></span>
        <span class="mx-2">•</span>
        <span><%= @post.created_at.strftime("%B %d, %Y") %></span>
        
        <% if @post.user == current_user %>
          <div class="ml-auto space-x-2">
            <%= link_to "Edit", edit_post_path(@post), class: "text-blue-500 hover:underline" %>
            <%= button_to "Delete", @post, method: :delete, 
                data: { confirm: "Are you sure you want to delete this post?" }, 
                class: "text-red-500 hover:underline" %>
          </div>
        <% end %>
      </div>
      
      <div class="prose max-w-none">
        <%= @post.content %>
      </div>
    </div>
  </article>
  
  <div class="bg-white rounded-lg shadow-md overflow-hidden mb-8">
    <div class="p-6">
      <h2 class="text-2xl font-bold mb-6">Comments</h2>
      
      <% if current_user %>
        <div class="mb-8" id="comment-form">
          <%= form_with model: [@post, @comment], 
                        data: { controller: "character-counter", 
                                action: "turbo:submit-end->character-counter#reset" } do |form| %>
            <div class="mb-4">
              <%= form.text_area :body, 
                  placeholder: "Add a comment...", 
                  rows: 3, 
                  required: true,
                  class: "w-full border rounded-lg p-2 focus:ring-2 focus:ring-blue-300 focus:border-blue-300",
                  data: { 
                    character_counter_target: "input",
                    action: "input->character-counter#count"
                  } %>
              <div class="text-right text-sm text-gray-500" data-character-counter-target="counter">0/500</div>
            </div>
            <%= form.submit "Post Comment", 
                class: "bg-blue-500 hover:bg-blue-600 text-white py-2 px-4 rounded" %>
          <% end %>
        </div>
      <% else %>
        <div class="bg-gray-100 p-4 rounded-lg mb-6">
          <p>Please <%= link_to "sign in", root_path, class: "text-blue-500 hover:underline" %> to leave a comment.</p>
        </div>
      <% end %>
      
      <div id="comments">
        <%= turbo_stream_from @post, :comments %>
        <% if @comments.any? %>
          <% @comments.each do |comment| %>
            <%= render partial: "comments/comment", locals: { comment: comment, post: @post } %>
          <% end %>
        <% else %>
          <p class="text-center text-gray-500 py-4">No comments yet. Be the first to share your thoughts!</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
