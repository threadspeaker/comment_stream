<div class="bg-white rounded-lg shadow-md overflow-hidden" id="<%= dom_id(post) %>">
  <div class="p-4">
    <h2 class="text-xl font-bold mb-2"><%= link_to post.title, post, class: "hover:text-blue-500" %></h2>
    <p class="text-gray-600 mb-4">
      By <%= post.user.name %> • <%= time_ago_in_words(post.created_at) %> ago
    </p>
    <div class="text-gray-800 mb-4">
      <%= truncate(post.content, length: 150) %>
    </div>
    <%= link_to "Read More", post, class: "text-blue-500 hover:underline" %>
  </div>
</div>
