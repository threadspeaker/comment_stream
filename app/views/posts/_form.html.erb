<%= form_with model: post do |form| %>
  <% if post.errors.any? %>
    <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6">
      <div class="font-medium text-red-700">
        <%= pluralize(post.errors.count, "error") %> prevented this post from being saved:
      </div>
      <ul class="mt-2 list-disc list-inside text-red-600">
        <% post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :title, required: true, 
        class: "w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div class="mb-6">
    <%= form.label :content, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_area :content, rows: 10, required: true, 
        class: "w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500",
        data: { 
          controller: "character-counter",
          character_counter_target: "input",
          action: "input->character-counter#count"
        } %>
    <div class="text-right text-sm text-gray-500 mt-1" data-character-counter-target="counter">0/2000</div>
  </div>

  <div class="flex items-center justify-end space-x-3">
    <% if post.persisted? %>
      <%= link_to "Cancel", post, class: "text-gray-600 hover:text-gray-900" %>
      <%= form.submit "Update Post", class: "bg-blue-500 hover:bg-blue-600 text-white py-2 px-4 rounded" %>
    <% else %>
      <%= link_to "Cancel", posts_path, class: "text-gray-600 hover:text-gray-900" %>
      <%= form.submit "Create Post", class: "bg-blue-500 hover:bg-blue-600 text-white py-2 px-4 rounded" %>
    <% end %>
  </div>
<% end %>
