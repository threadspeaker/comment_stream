<%= form_with model: post, class: "post__form" do |form| %>
  <% if post.errors.any? %>
    <div class="post__form-errors">
      <h2><%= pluralize(post.errors.count, "error") %> prevented this post from being saved:</h2>
      
      <ul class="post__form-errors-list">
        <% post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="post__form-group">
    <%= form.label :title, class: "post__form-label" %>
    <%= form.text_field :title, required: true, class: "post__form-input" %>
  </div>

  <div class="post__form-group">
    <div data-controller="character-counter" data-max-length="2000">
      <%= form.label :content, class: "post__form-label" %>
      <%= form.text_area :content, rows: 10, required: true, 
          class: "post__form-textarea",
          data: { 
            character_counter_target: "input",
            action: "input->character-counter#count"
          } %>
      <div class="post__form-counter" data-character-counter-target="counter">0/2000</div>
    </div>
  </div>

  <div class="post__form-actions">
    <% if post.persisted? %>
      <%= link_to "Cancel", post, class: "button button--secondary" %>
      <%= form.submit "Update Post", class: "button button--primary" %>
    <% else %>
      <%= link_to "Cancel", posts_path, class: "button button--secondary" %>
      <%= form.submit "Create Post", class: "button button--primary" %>
    <% end %>
  </div>
<% end %>
