<div class="posts__container">
  <div class="posts__header">
    <h1 class="posts__header-title">All Posts</h1>
    
    <div class="posts__header-actions">
      <% if current_user %>
        <%= link_to "New Post", new_post_path, class: "button button--primary" %>
        <%= button_to "Log Out", session_path, method: :delete, class: "button button--danger" %>
      <% else %>
        <%= link_to "Sign In", root_path, class: "button button--primary" %>
      <% end %>
    </div>
  </div>
  
  <% if @posts.any? %>
    <div class="posts__grid">
      <% @posts.each do |post| %>
        <%= render partial: "post", locals: { post: post } %>
      <% end %>
    </div>
  <% else %>
    <div class="posts__empty">
      <p class="posts__empty-message">No posts yet. Be the first to create one!</p>
      
      <% if current_user %>
        <%= link_to "Create Post", new_post_path, class: "button button--primary" %>
      <% end %>
    </div>
  <% end %>
</div>
